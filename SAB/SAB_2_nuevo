             fontsize=10, ha='center', weight='bold', alpha=0.6, zorder=3)

# 3. Dibujar aristas (líneas del grafo)
nx.draw_networkx_edges(G_critico, pos_critica, edge_color='gray', alpha=0.5, ax=ax)

# 4. --- NUEVO: Dibujar los polígonos envolventes ---
for node in G_critico.nodes():
    poly = poligonos_critica[node]
    center = pos_critica[node]
    
    # Extraer los bordes del polígono
    x_poly, y_poly = poly.exterior.xy
    
    # Rellenar la forma
    ax.fill(x_poly, y_poly, color='red', alpha=0.4, edgecolor='darkred', linewidth=1.5, zorder=4)

